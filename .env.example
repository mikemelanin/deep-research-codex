# Search provider
TAVILY_API_KEY=
RETRIEVER=tavily

# Bedrock LLMs (required)
FAST_LLM=bedrock:global.anthropic.claude-sonnet-4-6
SMART_LLM=bedrock:global.anthropic.claude-sonnet-4-6
STRATEGIC_LLM=bedrock:global.anthropic.claude-sonnet-4-6

# Embeddings via Bedrock
EMBEDDING=bedrock:amazon.titan-embed-text-v2:0

# AWS auth: use either AWS_PROFILE or direct keys
AWS_PROFILE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
# Or use Bedrock API key (bearer token)
AWS_BEARER_TOKEN_BEDROCK=

# Required region for Bedrock calls
AWS_DEFAULT_REGION=us-east-1

# Optional deep-research tuning
# These defaults are used by the main CLI path without any extra flags.
# Local comparison winner for moderate-budget deep runs:
# breadth=4 depth=2 concurrency=4 with slightly higher soft limits.
DEEP_RESEARCH_BREADTH=4
DEEP_RESEARCH_DEPTH=2
DEEP_RESEARCH_CONCURRENCY=4
SOFT_LIMIT_ENABLED=1
SOFT_LIMIT_TAVILY_CALLS=14
SOFT_LIMIT_BEDROCK_TOTAL_TOKENS=160000
SOFT_LIMIT_ELAPSED_SECONDS=540
SOFT_LIMIT_MAX_SUBQUERIES=8
