# Search provider
TAVILY_API_KEY=
RETRIEVER=tavily

# Bedrock LLMs (required)
FAST_LLM=bedrock:anthropic.claude-3-sonnet-20240229-v1:0
SMART_LLM=bedrock:anthropic.claude-3-sonnet-20240229-v1:0
STRATEGIC_LLM=bedrock:anthropic.claude-3-sonnet-20240229-v1:0

# Embeddings via Bedrock
EMBEDDING=bedrock:amazon.titan-embed-text-v2:0

# AWS auth: use either AWS_PROFILE or direct keys
AWS_PROFILE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
# Or use Bedrock API key (bearer token)
AWS_BEARER_TOKEN_BEDROCK=

# Required region for Bedrock calls
AWS_DEFAULT_REGION=us-east-1
